# ─── Application ───────────────────────────────────────
APP_NAME=Kinoscribe
DEBUG=true

# ─── Database ──────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/subtitle_translator.db

# ─── LLM / Ollama ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Optional: model used for the refine pass (set to same as OLLAMA_MODEL if single-pass)
OLLAMA_REFINE_MODEL=llama3

# ─── Translation Defaults ─────────────────────────────
DEFAULT_SOURCE_LANGUAGE=en
DEFAULT_TARGET_LANGUAGE=fr

# ─── Subtitle Constraints ─────────────────────────────
# Max characters per second before flagging as too dense
CPS_LIMIT=25
# Number of previous lines to include in the sliding window
SLIDING_WINDOW_SIZE=20

# ─── TMDB (optional, for metadata enrichment) ────────
TMDB_API_KEY=